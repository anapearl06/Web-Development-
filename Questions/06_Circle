<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create a Circle Using Border Radius</title>

    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            margin: 30px;
            line-height: 1.8;
            background-color: #f4f4f4;
        }

        h1 {
            color: #2c3e50;
        }

        .shape {
            width: 200px;
            height: 100px;
            background-color: lightblue;
            border: 3px solid royalblue;
            margin: 20px 0;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .rounded {
            border-radius: 15px;
        }

        .pill {
            border-radius: 50px;
        }

        .circle {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background-color: tomato;
            color: white;
        }

        .ellipse {
            width: 220px;
            height: 120px;
            border-radius: 50%;
            background-color: mediumseagreen;
            color: white;
        }

        .mixed-radius {
            border-radius: 30px 0 30px 0;
        }
    </style>
</head>

<body>

    <h1>Border Radius Examples</h1>

    <h2>1. Rounded Rectangle</h2>

    <div class="shape rounded">
        15px Radius
    </div>

    <h2>2. Pill Shape</h2>

    <div class="shape pill">
        50px Radius
    </div>

    <h2>3. Circle</h2>

    <div class="shape circle">
        Circle
    </div>

    <h2>4. Ellipse</h2>

    <div class="shape ellipse">
        Ellipse
    </div>

    <h2>5. Different Radius</h2>

    <div class="shape mixed-radius">
        Mixed Radius
    </div>

</body>
</html>